# ============================================================================
# VERCEL POSTGRES DATABASE CONFIGURATION
# ============================================================================
# 
# Get your DATABASE_URL from Vercel Postgres:
# 1. Go to https://vercel.com/dashboard
# 2. Select your project
# 3. Click "Storage" tab
# 4. Click on your Postgres database
# 5. Copy the "POSTGRES_URL_NON_POOLING" connection string
#
# Replace the placeholder below with your actual connection string:
# ============================================================================

DATABASE_URL="postgresql://default:COPY_YOUR_PASSWORD_HERE@aws-0-us-east-1.pooling.vercel-storage.com:6543/vercel"

# ============================================================================
# NEXTAUTH CONFIGURATION
# ============================================================================
# Generate a secure secret: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-random-secure-string-here"

# For development (http://localhost:3000)
NEXTAUTH_URL="http://localhost:3000"

# For production (replace with your deployed domain)
# NEXTAUTH_URL="https://yourdomain.com"

# ============================================================================
# OPTIONAL: FILE UPLOAD SERVICE
# ============================================================================
# If you want file uploads for gig attachments/project files
# NEXT_PUBLIC_UPLOAD_URL="https://your-bucket.s3.amazonaws.com"
